generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Empresa {
  id            String         @id @default(uuid())
  nombre        String
  slug          String         @unique
  activo        Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  usuarios      Usuario[]
  roles         Rol[]
  productos     Product[]
  mesas         Mesa[]
  pedidos       Pedido[]
  ventas        Venta[]
  facturas      Factura[]
  configuracion Configuracion?
  auditoria     Auditoria[]
  materiaPrimas MateriaPrima[]
  recetas       Receta[]
}

model Usuario {
  id        String      @id @default(uuid())
  empresaId String
  empresa   Empresa     @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  idusuario String
  nombre    String
  username  String
  email     String
  password  String
  rolId     String?
  rol       Rol?        @relation(fields: [rolId], references: [id], onDelete: SetNull)
  activo    Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  pedidos   Pedido[]    @relation("PedidoMesero")
  ventas    Venta[]     @relation("VentaMesero")
  facturas  Factura[]   @relation("FacturaMesero")
  Auditoria Auditoria[]

  @@unique([empresaId, idusuario])
  @@unique([empresaId, username])
  @@unique([empresaId, email])
  @@index([empresaId, rolId])
}

model Rol {
  id          String    @id @default(uuid())
  empresaId   String
  empresa     Empresa   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  idrol       String
  nombre      String
  descripcion String    @default("")
  color       String    @default("#7c3aed")
  permisos    String[]  @default([])
  activo      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  usuarios    Usuario[]

  @@unique([empresaId, idrol])
  @@unique([empresaId, nombre])
  @@index([empresaId, activo])
}

model Product {
  id           String        @id @default(uuid())
  empresaId    String
  empresa      Empresa       @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  idproducto   String
  nombre       String
  precio       Decimal       @db.Decimal(12, 2)
  descripcion  String        @default("")
  categoria    String
  stock        Int           @default(0)
  disponible   Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  pedidoItems  PedidoItem[]
  ventaItems   VentaItem[]
  facturaItems FacturaItem[]
  recetas      Receta[]

  @@unique([empresaId, idproducto])
  @@index([empresaId, categoria])
  @@index([empresaId, disponible])
}

model MateriaPrima {
  id             String   @id @default(uuid())
  empresaId      String
  empresa        Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  idMateriaPrima String
  nombre         String
  categoria      String
  stock          Int      @default(0)
  disponible     Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  unidad         String   @default("unidad")
  recetas        Receta[]

  @@unique([empresaId, idMateriaPrima])
  @@index([empresaId, categoria])
  @@index([empresaId, disponible])
}

model Receta {
  id          String @id @default(uuid())

  empresaId   String
  empresa     Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  productoId  String
  producto    Product @relation(fields: [productoId], references: [id], onDelete: Cascade)

  materiaPrimaId String
  materiaPrima   MateriaPrima @relation(fields: [materiaPrimaId], references: [id], onDelete: Cascade)

  cantidad Decimal @db.Decimal(10, 2)

  @@unique([productoId, materiaPrimaId, empresaId])
  @@index([empresaId])
}

model Mesa {
  id        String   @id @default(uuid())
  empresaId String
  empresa   Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  numero    Int
  capacidad Int      @default(4)
  estado    String   @default("disponible")
  pedidos   Pedido[] @relation("MesaPedidos")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([empresaId, numero])
  @@index([empresaId, estado])
}

model Pedido {
  id          String       @id @default(uuid())
  empresaId   String
  empresa     Empresa      @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  mesaId      String
  mesa        Mesa         @relation("MesaPedidos", fields: [mesaId], references: [id], onDelete: Restrict)
  meseroId    String?
  mesero      Usuario?     @relation("PedidoMesero", fields: [meseroId], references: [id], onDelete: SetNull)
  responsable String       @default("Sin asignar")
  total       Decimal      @db.Decimal(12, 2)
  estado      String       @default("pendiente")
  fecha       DateTime     @default(now())
  productos   PedidoItem[]
  ventas      Venta[]
  facturas    Factura[]

  @@index([empresaId, estado])
  @@index([empresaId, mesaId])
  @@index([empresaId, fecha])
}

model PedidoItem {
  id         String   @id @default(uuid())
  pedidoId   String
  pedido     Pedido   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  productoId String?
  producto   Product? @relation(fields: [productoId], references: [id], onDelete: SetNull)
  nombre     String
  precio     Decimal  @db.Decimal(12, 2)
  cantidad   Int

  @@index([pedidoId])
  @@index([productoId])
}

model Venta {
  id         String      @id @default(uuid())
  empresaId  String
  empresa    Empresa     @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  numero     String
  pedidoId   String?
  pedido     Pedido?     @relation(fields: [pedidoId], references: [id], onDelete: SetNull)
  mesa       Int?
  cliente    String      @default("")
  meseroId   String?
  mesero     Usuario?    @relation("VentaMesero", fields: [meseroId], references: [id], onDelete: SetNull)
  subtotal   Decimal     @db.Decimal(12, 2)
  iva        Decimal     @default(0) @db.Decimal(12, 2)
  propina    Decimal     @default(0) @db.Decimal(12, 2)
  total      Decimal     @db.Decimal(12, 2)
  metodoPago String      @default("Efectivo")
  estado     String      @default("completada")
  fecha      DateTime    @default(now())
  items      VentaItem[]
  facturas   Factura[]

  @@unique([empresaId, numero])
  @@index([empresaId, estado])
  @@index([empresaId, fecha])
}

model VentaItem {
  id         String   @id @default(uuid())
  ventaId    String
  venta      Venta    @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  productoId String?
  producto   Product? @relation(fields: [productoId], references: [id], onDelete: SetNull)
  nombre     String
  cantidad   Int
  precio     Decimal  @db.Decimal(12, 2)
  total      Decimal  @db.Decimal(12, 2)

  @@index([ventaId])
  @@index([productoId])
}

model Factura {
  id String @id @default(uuid())

  empresaId String
  empresa   Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  prefijo String? @default("POS")
  numero  String

  emisor  Json
  cliente Json

  subtotal Decimal @db.Decimal(12, 2)
  ivaTotal Decimal @default(0) @db.Decimal(12, 2)
  propina  Decimal @default(0) @db.Decimal(12, 2)
  total    Decimal @db.Decimal(12, 2)

  metodoPago String

  estado String @default("GENERADA")

  cufe    String?
  xmlPath String?
  pdfPath String?

  dianStatus   String?
  dianResponse Json?

  ventaId String?
  venta   Venta?  @relation(fields: [ventaId], references: [id], onDelete: SetNull)

  pedidoId String?
  pedido   Pedido? @relation(fields: [pedidoId], references: [id], onDelete: SetNull)

  meseroId String?
  mesero   Usuario? @relation("FacturaMesero", fields: [meseroId], references: [id], onDelete: SetNull)

  mesa Int?

  fecha DateTime @default(now())

  items FacturaItem[]

  @@unique([empresaId, numero])
  @@index([empresaId, fecha])
}

model FacturaItem {
  id String @id @default(uuid())

  facturaId String
  factura   Factura @relation(fields: [facturaId], references: [id], onDelete: Cascade)

  productoId String?
  producto   Product? @relation(fields: [productoId], references: [id], onDelete: SetNull)

  codigo String?

  nombre String

  cantidad Int

  precio Decimal @db.Decimal(12, 2)

  ivaPorcentaje Decimal @default(19) @db.Decimal(5, 2)

  subtotal Decimal @db.Decimal(12, 2)

  total Decimal @db.Decimal(12, 2)

  @@index([facturaId])
  @@index([productoId])
}

model Configuracion {
  id          String   @id @default(uuid())
  empresaId   String   @unique
  empresa     Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  clave       String   @default("facturacion")
  nombre      String   @default("SIIGO S.A.S")
  nit         String   @default("800200100-0")
  direccion   String   @default("Cali, Colombia")
  telefono    String   @default("")
  resolucion  String   @default("")
  autorizada  String   @default("")
  prefijo     String   @default("POS")
  email       String   @default("")
  responsable String   @default("Responsable de IVA")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([empresaId, clave])
}

model Auditoria {
  id         String   @id @default(uuid())
  empresaId  String
  empresa    Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  usuarioId  String?
  usuario    Usuario? @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  tipo       String
  accion     String
  modulo     String
  detalle    String   @default("")
  exito      Boolean  @default(true)
  nivel      String   @default("info")
  metodo     String?
  ruta       String?
  statusCode Int?
  duracionMs Int?
  ip         String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([empresaId, createdAt])
  @@index([empresaId, usuarioId, createdAt])
  @@index([empresaId, tipo, createdAt])
  @@index([empresaId, accion, createdAt])
}
